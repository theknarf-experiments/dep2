#!/usr/bin/env bash
#MISE description="Live cloc: line counts by crate with Rust in-file tests split from code (arg: root dir, default 'crates'). Ctrl+C to stop."
#
# cloc-style line counts (code/test/comment/blank) grouped by crate, with Rust
# in-file tests (`#[cfg(test)] mod`) split out from production code. The engine is
# incremental, so this serves it and re-renders the table live — you watch the
# counts converge, and they update if you edit files — until you Ctrl+C.
#
#   mise run cloc                 # over `crates`
#   mise run cloc crates/strata/src
set -euo pipefail
cd "${MISE_PROJECT_ROOT:-$(cd "$(dirname "$0")/../.." && pwd)}"

ROOT="${1:-crates}"

if [ ! -f grammars/tree-sitter-rust.wasm ]; then
  echo "missing grammars/tree-sitter-rust.wasm" >&2
  echo "build it first: mise run build-grammar tree-sitter-rust" >&2
  exit 1
fi
GRAMMARS="rs=./grammars/tree-sitter-rust.wasm"
[ -f grammars/tree-sitter-javascript.wasm ] && GRAMMARS="$GRAMMARS,js=./grammars/tree-sitter-javascript.wasm"
[ -f grammars/tree-sitter-typescript.wasm ] && GRAMMARS="$GRAMMARS,ts=./grammars/tree-sitter-typescript.wasm"

echo "building dep2..." >&2
cargo build -p dep2
BIN=target/debug/dep2
ADDR=127.0.0.1:7896

"$BIN" run examples/cloc.dl \
  --source "treesitter:root=$ROOT;grammars=$GRAMMARS" \
  --addr "$ADDR" >/dev/null 2>&1 &
PID=$!
trap 'kill "$PID" 2>/dev/null || true' EXIT
# Ctrl+C (or kill) is the normal way to stop this live view — exit cleanly so the
# task isn't reported as failed.
trap 'exit 0' INT TERM

dump() { "$BIN" query "$1" --addr "$ADDR" 2>/dev/null | grep ', ' || true; }

render() {
  {
    dump prod_code | sed 's/$/, code/'
    dump test_code | sed 's/$/, test/'
    dump comment   | sed 's/$/, comment/'
    dump blank     | sed 's/$/, blank/'
  } | awk -F', ' '
  { key = $1; lang[key] = $2; v[key, $4] = $3; seen[key] = 1 }
  END {
    printf "%-24s %-6s %8s %8s %9s %8s\n", "crate", "lang", "code", "test", "comment", "blank"
    printf "%-24s %-6s %8s %8s %9s %8s\n", "------------------------", "------", "--------", "--------", "---------", "--------"
    n = 0
    for (k in seen) order[++n] = k
    for (i = 2; i <= n; i++) { x = order[i]; j = i - 1; while (j >= 1 && order[j] > x) { order[j+1] = order[j]; j-- } order[j+1] = x }
    for (i = 1; i <= n; i++) {
      k = order[i]
      c = v[k,"code"]+0; t = v[k,"test"]+0; cm = v[k,"comment"]+0; b = v[k,"blank"]+0
      tc += c; tt += t; tcm += cm; tb += b
      printf "%-24s %-6s %8d %8d %9d %8d\n", k, lang[k], c, t, cm, b
    }
    printf "%-24s %-6s %8s %8s %9s %8s\n", "------------------------", "------", "--------", "--------", "---------", "--------"
    printf "%-24s %-6s %8d %8d %9d %8d\n", "SUM", "", tc, tt, tcm, tb
  }'
}

# Live loop: re-render until Ctrl+C. The counts climb as the engine computes and
# settle once it's done; editing a file under the root updates them.
while kill -0 "$PID" 2>/dev/null; do
  table="$(render)"
  printf '\033[H\033[J' # home + clear
  echo "cloc — live over '$ROOT' (updates as files change; Ctrl+C to stop)"
  echo
  if [ -n "$table" ]; then echo "$table"; else echo "  computing..."; fi
  sleep 1
done
