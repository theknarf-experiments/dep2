#!/usr/bin/env bash
#MISE description="Live import-graph web UI: run the dep2 engine and the React SPA together (mprocs). Quit mprocs (q) to stop both. (arg: folder to analyze, default this repo's crates/; works on any project)"
#
# Builds dep2, then hands off to mprocs (see graph.mprocs.yaml) which runs two procs:
#   1. engine — dep2 over examples/import_graph.dl, query API at $GRAPH_ADDR
#   2. web    — the Vite dev server (web/), the React graph SPA
#
#   mise run graph                      # this repo's crates/
#   mise run graph ../other-project     # any folder, relative to your shell's cwd
#   mise run graph /abs/path/to/crates  # or an absolute path
#
# Open the URL the `web` pane prints (http://localhost:5173). Quit mprocs to stop.
set -euo pipefail
# Where you invoked `mise run` (mise runs the task from the project root, but
# records this), so a relative path argument resolves against your shell's dir.
ORIG_CWD="${MISE_ORIGINAL_CWD:-$PWD}"
cd "${MISE_PROJECT_ROOT:-$(cd "$(dirname "$0")/../.." && pwd)}"

# Folder to analyze. With no argument, analyze this repo's crates/. A path
# argument may be absolute or relative to where you ran the command; it is
# resolved to an absolute path so the engine can read any project's sources.
if [ "$#" -ge 1 ]; then
  case "$1" in
    /*) ROOT="$1" ;;
    *) ROOT="$ORIG_CWD/$1" ;;
  esac
else
  ROOT="$PWD/crates"
fi
if [ ! -d "$ROOT" ]; then
  echo "graph: '$ROOT' is not a directory" >&2
  exit 1
fi
ROOT="$(cd "$ROOT" && pwd)"

if [ ! -f grammars/tree-sitter-rust.wasm ]; then
  echo "missing grammars/tree-sitter-rust.wasm" >&2
  echo "build it first: mise run build-grammar tree-sitter-rust" >&2
  exit 1
fi
# Map every extension we have a grammar for. import_graph.dl reads source
# imports (Rust `use`, JS/TS `import`) and project manifests (Cargo.toml,
# package.json) to derive modules + the workspace, so the TOML/YAML/JSON grammars
# matter too; HTML/CSS are included so those files appear in the graph.
GRAMMARS="rs=./grammars/tree-sitter-rust.wasm"
add_grammar() { # <wasm-basename> <ext>[,<ext>...]
  local wasm="grammars/$1.wasm" exts="$2"
  [ -f "$wasm" ] || return 0
  local e
  IFS=',' read -ra e <<<"$exts"
  for x in "${e[@]}"; do GRAMMARS="$GRAMMARS,$x=./$wasm"; done
}
add_grammar tree-sitter-javascript js,jsx,mjs,cjs
add_grammar tree-sitter-typescript ts,tsx
add_grammar tree-sitter-json json
add_grammar tree-sitter-toml toml
add_grammar tree-sitter-html html,htm
add_grammar tree-sitter-css css
# (tree-sitter-yaml needs an external scanner the wasm runtime can't load, so
# pnpm-workspace.yaml isn't parsed; the workspace is inferred from the modules.)

# mprocs.yaml reads these.
export GRAPH_ROOT="$ROOT"
export GRAPH_GRAMMARS="$GRAMMARS"
export GRAPH_ADDR="127.0.0.1:7878"

echo "building dep2..." >&2
cargo build -p dep2

if [ ! -d web/node_modules ]; then
  echo "installing web deps (first run)..." >&2
  pnpm install
fi

# mprocs runs both processes in panes and stops them together on quit.
exec pnpm exec mprocs --config .mise/tasks/graph.mprocs.yaml
