#!/usr/bin/env bash
#MISE description="Live import-graph web UI: serve the engine over a project and a React SPA that visualizes its import graph. Ctrl+C to stop. (arg: root dir, default 'crates')"
#
# Runs two things and ties their lifetimes together:
#   1. the dep2 engine over examples/import_graph.dl (CORS enabled), serving the
#      crate_/file_ edge relations at http://127.0.0.1:7878
#   2. the Vite dev server (web/), a React + cytoscape SPA that polls those
#      relations and draws a live force-directed import graph
#
#   mise run graph                 # over `crates`
#   mise run graph path/to/project # over another tree
#
# Open the URL Vite prints (http://localhost:5173). Ctrl+C stops both.
set -euo pipefail
cd "${MISE_PROJECT_ROOT:-$(cd "$(dirname "$0")/../.." && pwd)}"

ROOT="${1:-crates}"

if [ ! -f grammars/tree-sitter-rust.wasm ]; then
  echo "missing grammars/tree-sitter-rust.wasm" >&2
  echo "build it first: scripts/build-grammar.sh tree-sitter-rust ./grammars" >&2
  exit 1
fi
# import_graph.dl understands Rust `use` and JS/TS `import`/`export ... from`.
# Map every JS/TS extension (incl. .tsx/.jsx) to its grammar; the TypeScript
# grammar parses TSX fine.
GRAMMARS="rs=./grammars/tree-sitter-rust.wasm"
if [ -f grammars/tree-sitter-javascript.wasm ]; then
  GRAMMARS="$GRAMMARS,js=./grammars/tree-sitter-javascript.wasm,jsx=./grammars/tree-sitter-javascript.wasm,mjs=./grammars/tree-sitter-javascript.wasm,cjs=./grammars/tree-sitter-javascript.wasm"
fi
if [ -f grammars/tree-sitter-typescript.wasm ]; then
  GRAMMARS="$GRAMMARS,ts=./grammars/tree-sitter-typescript.wasm,tsx=./grammars/tree-sitter-typescript.wasm"
fi

ADDR=127.0.0.1:7878

echo "building dep2..." >&2
cargo build -p dep2
BIN=target/debug/dep2

echo "starting engine on http://$ADDR over '$ROOT'..." >&2
"$BIN" run examples/import_graph.dl \
  --source "treesitter:root=$ROOT;grammars=$GRAMMARS" \
  --addr "$ADDR" >/dev/null 2>&1 &
ENGINE=$!
# Kill the engine when this task exits for any reason; exit cleanly on Ctrl+C so
# the live view isn't reported as a failed task.
trap 'kill "$ENGINE" 2>/dev/null || true' EXIT
trap 'exit 0' INT TERM

cd web
if [ ! -d node_modules ]; then
  echo "installing web deps (first run)..." >&2
  npm install
fi

echo >&2
echo "  engine:  http://$ADDR/relations" >&2
echo "  web UI:  Vite will print a URL below (usually http://localhost:5173)" >&2
echo >&2

# Foreground: Ctrl+C stops Vite, then the EXIT trap stops the engine.
npm run dev
