#!/usr/bin/env bash
#MISE description="Build a tree-sitter grammar to an ABI-compatible .wasm (args: <npm-pkg|github:owner/repo> [out-dir=grammars] [subdir] [wasm-name])"
#
# The grammar .wasm must be built with a tree-sitter CLI whose version matches
# the runtime `tree-sitter` crate, otherwise loading fails with errors like
# "failed to parse dylink section". This installs a matching CLI in a temp dir,
# regenerates the parser (so the ABI matches the CLI), and builds the wasm via
# the tree-sitter toolchain (fetches a wasi-sdk on first run).
#
#   mise run build-grammar tree-sitter-rust
#   mise run build-grammar tree-sitter-toml
#   # markdown ships two sub-grammars in one npm package; build the block one:
#   mise run build-grammar @tree-sitter-grammars/tree-sitter-markdown grammars tree-sitter-markdown tree-sitter-markdown
#   # MDX has no npm release; build straight from GitHub:
#   mise run build-grammar github:srazzak/tree-sitter-mdx
#
# Args:
#   1 PKG       npm package name, or `github:owner/repo` (git source)
#   2 OUT_DIR   output directory (default: grammars)
#   3 SUBDIR    subdirectory inside the package that holds grammar.js (optional;
#               markdown nests block/inline grammars in subdirs)
#   4 WASM_NAME output basename without .wasm (default: derived from SUBDIR/PKG)
#
# Requires: npm, and either a local emscripten or Docker (the CLI uses one to
# compile to wasm). npm here bootstraps the third-party tree-sitter CLI in a
# throwaway dir — unrelated to the pnpm workspace.
set -euo pipefail
cd "${MISE_PROJECT_ROOT:-$(cd "$(dirname "$0")/../.." && pwd)}"

PKG="${1:?usage: mise run build-grammar <npm-pkg|github:owner/repo> [out-dir] [subdir] [wasm-name]}"
OUT_DIR="${2:-grammars}"
SUBDIR="${3:-}"
WASM_NAME="${4:-}"

# Keep in sync with the `tree-sitter` version in the crate Cargo.toml files.
TS_CLI_VERSION="0.26"

OUT_DIR="$(mkdir -p "$OUT_DIR" && cd "$OUT_DIR" && pwd)"

WORK="$(mktemp -d)"
trap 'rm -rf "$WORK"' EXIT
cd "$WORK"
npm init -y >/dev/null 2>&1
CLI="$WORK/node_modules/.bin/tree-sitter"

# Fetch the grammar sources. github: specs are cloned (no npm release needed);
# everything else is an npm install. The CLI and the npm grammar are installed in
# one command — a second `npm install` would prune the first `--no-save` package.
case "$PKG" in
  github:*)
    REPO="${PKG#github:}"
    echo "==> installing tree-sitter-cli@^${TS_CLI_VERSION}" >&2
    npm install --no-save "tree-sitter-cli@^${TS_CLI_VERSION}" >/dev/null 2>&1
    echo "==> cloning https://github.com/${REPO}" >&2
    git clone --depth 1 "https://github.com/${REPO}" "$WORK/grammar" >/dev/null 2>&1
    SRC="$WORK/grammar"
    BASENAME="$(basename "$REPO")"
    ;;
  *)
    echo "==> installing tree-sitter-cli@^${TS_CLI_VERSION} and ${PKG}" >&2
    npm install --no-save "tree-sitter-cli@^${TS_CLI_VERSION}" "${PKG}" >/dev/null 2>&1
    SRC="$WORK/node_modules/${PKG}"
    BASENAME="$(basename "$PKG")"
    ;;
esac

GRAMMAR_DIR="$SRC${SUBDIR:+/$SUBDIR}"
[ -n "$SUBDIR" ] && BASENAME="$(basename "$SUBDIR")"
[ -n "$WASM_NAME" ] && BASENAME="$WASM_NAME"
OUT_WASM="$OUT_DIR/${BASENAME}.wasm"

if [ ! -f "$GRAMMAR_DIR/grammar.js" ] && [ ! -f "$GRAMMAR_DIR/src/grammar.json" ]; then
  echo "no grammar found in $GRAMMAR_DIR" >&2
  exit 1
fi

echo "==> tree-sitter $("$CLI" --version)" >&2
# Regenerate parser.c with this CLI so the wasm ABI matches the runtime; if the
# grammar can't be regenerated, fall back to the published parser.c.
( cd "$GRAMMAR_DIR" && "$CLI" generate >/dev/null 2>&1 ) ||
  echo "==> generate failed; building from the shipped parser.c" >&2
echo "==> building ${GRAMMAR_DIR} -> ${OUT_WASM}" >&2
"$CLI" build --wasm "$GRAMMAR_DIR" -o "$OUT_WASM"

echo "==> done: ${OUT_WASM}" >&2
