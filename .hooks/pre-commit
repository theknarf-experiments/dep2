#!/usr/bin/env bash
# Pre-commit hook: enforce formatting, that the workspace type-checks, and that
# the tests pass.
#
# Activate once per clone with:  mise run setup-hooks
# (that points git's core.hooksPath at this directory).
set -euo pipefail

echo "▶ cargo fmt --all --check"
cargo fmt --all -- --check

echo "▶ cargo check --workspace"
cargo check --workspace

echo "▶ cargo nextest run --workspace"
cargo nextest run --workspace

echo "✓ pre-commit checks passed"
