{
  "name": "@dep2/force-graph",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Reusable React Three Fiber force-directed graph (instanced nodes/edges, d3-force in a worker, pan/zoom/drag/hover/select). Consumed as TypeScript source.",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "storybook": "storybook dev -p 6006 --no-open",
    "build-storybook": "storybook build",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@react-three/drei": ">=9",
    "@react-three/fiber": ">=8",
    "react": ">=18",
    "react-dom": ">=18",
    "three": ">=0.160"
  },
  "dependencies": {
    "d3-force": "^3.0.0"
  },
  "devDependencies": {
    "@react-three/drei": "^9.122.0",
    "@react-three/fiber": "^8.18.0",
    "@webgpu/types": "^0.1.70",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/react": "^8.6.14",
    "@storybook/react-vite": "^8.6.14",
    "@types/d3-force": "^3.0.10",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/three": "^0.169.0",
    "@vitejs/plugin-react": "^4.3.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "storybook": "^8.6.14",
    "three": "^0.169.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}
